# ========== AI model ==========
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# ========== RAG ==========
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_DISABLED=false
# Used by direct backend runs; Compose pins /app/chroma_db to its bind mount.
CHROMA_DB_PATH=./chroma_db

# Per-request ingestion limits. Keep the reverse-proxy body limit at or above
# UPLOAD_MAX_BYTES. PDF pages, extracted characters and final chunks are all
# checked before vectors are persisted.
UPLOAD_MAX_BYTES=10485760
RAG_MAX_PDF_PAGES=100
RAG_MAX_TEXT_CHARS=200000
RAG_MAX_CHUNKS=500

# Maximum HTTP response body accepted by URL fetch/import. Redirect targets are
# revalidated by the backend; private and metadata-network targets are rejected.
CRAWLER_MAX_RESPONSE_BYTES=2097152
CRAWLER_MAX_REDIRECTS=5
CRAWLER_MAX_TEXT_CHARS=20000
FETCH_URL_RATE_LIMIT_PER_MINUTE=10

# ========== Application/security ==========
APP_ENV=development
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=30
PASSWORD_PBKDF2_ITERATIONS=310000
LOGIN_FAILURE_LIMIT=5
LOGIN_FAILURE_WINDOW_SECONDS=900

# Browser session lifetime and cookie policy. In production use HTTPS and set
# SESSION_COOKIE_SECURE=true. SameSite=none also requires Secure=true.
SESSION_TTL_HOURS=168
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
AUTH_SESSION_RETENTION_DAYS=30
AUTH_SESSION_CLEANUP_INTERVAL_SECONDS=3600

# Shared rate limiting. Docker Compose supplies redis://redis:6379/0 by default.
# Direct local/test runs may leave REDIS_URL blank only when the explicit memory
# fallback is enabled. Production never permits the memory fallback.
REDIS_URL=
RATE_LIMIT_ALLOW_MEMORY_FALLBACK=true
RATE_LIMIT_KEY_PREFIX=ai-job-consultant
CHAT_REQUEST_LEASE_SECONDS=300

# Comma-separated exact origins. Wildcards are rejected because cookies are used.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:80,http://127.0.0.1:80,http://localhost:5173,http://127.0.0.1:5173

# Only enable forwarded client IPs behind a trusted reverse proxy. CIDRs are
# checked against the direct peer before X-Forwarded-For/X-Real-IP is accepted.
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=172.30.10.10/32

# IANA timezone used for administrator "today" metrics.
BUSINESS_TIMEZONE=Asia/Shanghai

# Set both values for the first start only, then remove them after verifying the
# super-admin account. Leaving both blank disables bootstrap.
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=

# ========== Database ==========
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=aiagent
DB_PASSWORD=replace-with-a-long-random-app-password
DB_NAME=ai_assistant
